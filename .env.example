# =====================================================
# Masters Professional Academy — Environment Variables
# =====================================================
# Copy this file and rename it to .env
# Fill in all values below — never share this file
# =====================================================

# MongoDB Connection String
# Get free cluster from: https://mongodb.com/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/mpa-app
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.mongodb.net/mpa-app

# JWT Secret — make this a long random string (e.g. 64+ characters)
JWT_SECRET=your-very-long-random-secret-key-change-this-to-something-secure-123456

# JWT Expiry
JWT_EXPIRES_IN=7d

# Anthropic Claude API Key
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-actual-key-here

# Google Cloud Vision API Key
# Get from: https://console.cloud.google.com
GOOGLE_VISION_API_KEY=AIza-your-actual-key-here

# Admin Secret — used to create the first admin account
# Change this to something only you know
ADMIN_SECRET=mpa-admin-secret-2025

# Server Port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
